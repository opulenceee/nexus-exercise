# Copy this file to `.env` (which is gitignored) before running.
# These are DEV placeholders only — never commit real secrets.

# --- Postgres (used by the db container) ---
POSTGRES_USER=nexus
POSTGRES_PASSWORD=local-dev-password
POSTGRES_DB=nexus
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Application ---
# SQLAlchemy + psycopg3 dialect. Host "db" is the compose service name.
DATABASE_URL=postgresql+psycopg://nexus:local-dev-password@db:5432/nexus

# Host port the API is published on (change if 8000 is already taken locally).
APP_PORT=8000

# Bearer token that protects the Admin API (single internal operator).
ADMIN_API_TOKEN=dev-admin-token-change-me

# --- Demo seed data (created on container start) ---
SEED_ON_START=true
# Plaintext token for the demo reseller; stored HASHED in the DB on seed.
SEED_RESELLER_TOKEN=dev-reseller-token-change-me
